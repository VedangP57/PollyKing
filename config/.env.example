BANKROLL_USDC=500
KELLY_FRACTION=0.25

# --- POLYMARKET LIVE TRADING ---
POLYMARKET_PRIVATE_KEY=           # wallet private key (0x...)
POLYMARKET_WALLET_ADDRESS=        # proxy wallet address from polymarket.com/settings
# Signature type: 0=EOA (programmatic), 1=POLY_PROXY (Magic Link), 2=GNOSIS_SAFE (browser users)
POLYMARKET_SIGNATURE_TYPE=0

# --- KALSHI LIVE TRADING ---
KALSHI_API_KEY=
KALSHI_API_SECRET=

# --- GAP THRESHOLDS ---
CROSS_PLATFORM_MIN_GAP_CENTS=5    # minimum gap for Poly vs Kalshi trades
INTERNAL_MIN_GAP_CENTS=8          # minimum gap for internal Poly negRisk trades

# --- POSITION SIZING ---
MAX_DEPTH_FRACTION=0.25           # max fraction of min(poly_liq, kalshi_liq) to bet
FEE_CACHE_REFRESH_INTERVAL_S=3600 # how often to refresh per-token taker fee from CLOB API

# --- CIRCUIT BREAKER ---
CIRCUIT_BREAKER_MAX_FAILURES=3    # failures in window before market is paused
CIRCUIT_BREAKER_WINDOW_S=600      # rolling window for failure counting (seconds)

# --- RESOLUTION MISMATCH ---
MAX_RESOLUTION_DELTA_HOURS=6      # pairs with Kalshi/Poly close time delta > this are excluded
