# PolyyKing — Arbitrage Bot Configuration
# Copy to config/.env or project root .env and fill in your values.
# Run: scripts/backfill_matches.py  (fetches markets, auto-creates pairs)
#      python-core/main.py          (starts the bot)

# ── Trading Mode ──────────────────────────────────────────────────────────────
DRY_RUN=true           # true = simulate only, no real money. Set false for live.

# ── Risk Limits ───────────────────────────────────────────────────────────────
MIN_GAP_CENTS=5        # Minimum arbitrage gap to act on (cents)
MAX_GAP_CENTS=30       # Maximum gap -- larger may indicate stale data
MIN_BET_USDC=10        # Minimum bet size per trade ($)
MAX_BET_USDC=100       # Maximum bet size per trade ($)
MAX_DAILY_LOSS_USDC=50 # Bot pauses when daily losses exceed this ($)
MAX_OPEN_POSITIONS=20  # Maximum concurrent open positions

# ── Storage ───────────────────────────────────────────────────────────────────
DB_PATH=data/trades.db
MARKETS_JSON=config/markets.json

# ── Polymarket ────────────────────────────────────────────────────────────────
# Price feed and market discovery: fully PUBLIC, no key needed.
# Only needed for live order placement (DRY_RUN=false):
POLYMARKET_API_KEY=
POLYMARKET_PRIVATE_KEY=
POLYMARKET_CLOB_URL=https://clob.polymarket.com
POLYMARKET_GAMMA_URL=https://gamma-api.polymarket.com

# ── Kalshi ────────────────────────────────────────────────────────────────────
# Market data and prices are PUBLIC -- no API key required.
# https://api.elections.kalshi.com/trade-api/v2 works without authentication.
# KALSHI_API_KEY only needed for live trading (DRY_RUN=false):
KALSHI_API_URL=https://api.elections.kalshi.com/trade-api/v2
KALSHI_API_KEY=
KALSHI_API_SECRET=

# ── Rust Binary ───────────────────────────────────────────────────────────────
RUST_BINARY=rust-core/target/release/arb
