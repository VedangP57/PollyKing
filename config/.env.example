# --- CORE ---
DRY_RUN=true                      # set false only for live trading
BANKROLL_USDC=500
KELLY_FRACTION=0.25
MIN_BET_USDC=10
MAX_BET_USDC=100
MAX_OPEN_POSITIONS=5
MAX_DAILY_LOSS_USDC=50
MAX_CATEGORY_EXPOSURE_USDC=200

# --- POLYMARKET LIVE TRADING ---
POLYMARKET_PRIVATE_KEY=           # wallet private key (0x...)
POLYMARKET_WALLET_ADDRESS=        # proxy wallet address from polymarket.com/settings
# Signature type: 0=EOA (programmatic), 1=POLY_PROXY (Magic Link), 2=GNOSIS_SAFE (browser users)
POLYMARKET_SIGNATURE_TYPE=0

# --- KALSHI LIVE TRADING ---
KALSHI_API_KEY=
KALSHI_API_SECRET=
KALSHI_API_URL=https://api.elections.kalshi.com/trade-api/v2

# --- GAP THRESHOLDS ---
CROSS_PLATFORM_MIN_GAP_CENTS=5    # minimum gap for Poly vs Kalshi trades
INTERNAL_MIN_GAP_CENTS=8          # minimum gap for internal Poly negRisk trades
MIN_GAP_CENTS=5
MAX_GAP_CENTS=30
MIN_LIQUIDITY_USDC=500            # minimum book depth required on each leg

# --- EV GATE ---
EV_MIN_CENTS=1.0                  # minimum net EV after fees to accept a gap
EV_TAKER_FEE_RATE=0.02            # default Polymarket taker fee (overridden by fee cache)
EV_SLIPPAGE_CENTS=0.5             # expected slippage allowance per leg

# --- POSITION SIZING ---
MAX_DEPTH_FRACTION=0.25           # max fraction of min(poly_liq, kalshi_liq) to bet
FEE_CACHE_REFRESH_INTERVAL_S=3600 # how often to refresh per-token taker fee from CLOB API

# --- CIRCUIT BREAKER ---
CIRCUIT_BREAKER_MAX_FAILURES=3    # failures in window before market is paused
CIRCUIT_BREAKER_WINDOW_S=600      # rolling window for failure counting (seconds)

# --- RESOLUTION MISMATCH ---
MAX_RESOLUTION_DELTA_HOURS=6      # pairs with Kalshi/Poly close time delta > this are excluded

# --- PATHS (optional — defaults shown) ---
DB_PATH=data/trades.db
MARKETS_JSON=config/markets.json
RUST_BINARY=rust-core/target/release/arb
LOG_DIR=logs
RECONCILE_INTERVAL_S=300

# --- MISC ---
DISABLE_SSL=                      # set to "1" to disable SSL (dev/proxy environments only)
